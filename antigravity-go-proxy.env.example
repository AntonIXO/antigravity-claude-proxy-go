# Required local-only API authentication for /v1/* routes.
ANTIGRAVITY_PROXY_API_KEY=replace-with-a-local-secret

# Optional overrides. Refresh credentials are read from the installed agy
# executable when needed; no OAuth client values belong in this file.
# ACCOUNT_STRATEGY=hybrid
# AGY_PROJECT_ID=
# AGY_TOKEN_WRITEBACK=0
# AGY_TOKEN_PATH=
# AGY_BINARY_PATH=
