# Required local-only API authentication for /v1/* routes.
ANTIGRAVITY_PROXY_API_KEY=replace-with-a-local-secret

# Required when an agy token or OAuth account needs an access-token refresh.
# Keep the official CLI's installed-app credentials in this root-only file;
# never commit their values.
AGY_OAUTH_CLIENT_ID=replace-with-your-installed-app-client-id
AGY_OAUTH_CLIENT_SECRET=replace-with-your-installed-app-client-secret

# Optional overrides.
# ACCOUNT_STRATEGY=hybrid
# AGY_PROJECT_ID=
# AGY_TOKEN_WRITEBACK=0
